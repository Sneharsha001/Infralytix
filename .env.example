# =============================================================================
# Infralytix — Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in every value marked with <CHANGE_ME>
#   3. NEVER commit the .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME=Infralytix
APP_VERSION=0.1.0
APP_ENV=development          # development | staging | production
DEBUG=true                   # Set to false in production

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173

# -----------------------------------------------------------------------------
# DATABASE — MySQL 8.4
# -----------------------------------------------------------------------------
DB_HOST=localhost             # Use 'mysql' when running inside Docker
DB_PORT=3306
DB_NAME=infralytix_db
DB_USER=infralytix_user
DB_PASSWORD=<CHANGE_ME>      # Strong password required

MYSQL_ROOT_PASSWORD=<CHANGE_ME>  # Root password for MySQL container

# -----------------------------------------------------------------------------
# SECURITY — JWT Authentication
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=<CHANGE_ME>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# AI AGENTS (Sprint 4+)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=<CHANGE_ME>
GEMINI_MODEL=gemini-1.5-pro

# -----------------------------------------------------------------------------
# CLOUD — AWS (Sprint 13+)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<CHANGE_ME>
AWS_SECRET_ACCESS_KEY=<CHANGE_ME>
AWS_S3_BUCKET=infralytix-reports

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json              # json | text (use json in production)
