# =============================================================================
# Infralytix — .gitignore
# Covers: Python, Node.js, Docker, IDE, OS, Secrets
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS — NEVER COMMIT THESE
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/
.secrets/

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
.uv/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Jupyter
.ipynb_checkpoints
*.ipynb

# Pyenv
.python-version

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# Spyder
.spyderproject.db
.spyproject

# Rope
.ropeproject

# mkdocs
/site

# uv
uv.lock

# -----------------------------------------------------------------------------
# NODE / FRONTEND
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Build output
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
*.local

# Storybook
.storybook/storybook-static/

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
.dockerignore

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
*.sql.bak
*.db
*.sqlite
*.sqlite3
mysql_data/
postgres_data/

# Alembic — keep versions tracked, ignore pycache
backend/alembic/__pycache__/
backend/alembic/versions/__pycache__/

# -----------------------------------------------------------------------------
# IDEs / EDITORS
# -----------------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project

# Vim
[._]*.s[a-v][a-z]
!*.svg
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
*~
tags
[._]*.un~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.tmp
*.temp
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
*.log.*

# -----------------------------------------------------------------------------
# CLOUD / TERRAFORM
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# AWS
.aws/

# -----------------------------------------------------------------------------
# MISC
# -----------------------------------------------------------------------------
*.bak
*.swp
*.swo
tmp/
temp/
.tmp/
