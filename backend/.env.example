# =============================================================================
# Infralytix Backend — Environment Variables
# =============================================================================
# Copy to .env and fill in values before running the application.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Infralytix
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Database (MySQL 8.4) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=infralytix_user
DB_PASSWORD=<CHANGE_ME>
DB_NAME=infralytix_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

MYSQL_ROOT_PASSWORD=<CHANGE_ME>

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=<CHANGE_ME>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# ─── AI (Sprint 4+) ──────────────────────────────────────────────────────────
GEMINI_API_KEY=<CHANGE_ME>
GEMINI_MODEL=gemini-1.5-pro
